  "id_based_queries": {},
  "general": {
    "greeting": {
      "patterns": [
        "hi",
        "hello",
        "hey",
        "good morning",
        "good afternoon",
        "good evening"
      ],
      "response": "Hello! \uD83D\uDC4B There! I am EVSProcure Support Bot How can I help you today?"
    },
    "voice_greeting": {
      "patterns": [
        "hey evs",
        "hey e v s",
        "hey e.v.s",
        "hello evs",
        "hi evs"
      ],
      "response": "Hello! I'm EVS Assistant. I'm ready to help with procurement tasks. What would you like to do?"
    },
    "voice_end_session": {
      "patterns": [
        "stop listening",
        "goodbye",
        "that's all",
        "bye",
        "stop",
        "end session",
        "i'm done",
        "nothing else",
        "no thanks"
      ],
      "response": "Goodbye! EVS Assistant signing off. Say Hey EVS to start again."
    },
    "help": {
      "patterns": [
        "help",
        "what can you do",
        "features",
        "support"
      ],
      "response": "I can help you with:\n\n\uD83D\uDED2 Create New Cart - Create a new procurement cart\n\uD83D\uDED2 Cart Status - Check the status of your existing cart\n\u2705 Approve Cart - Approve pending procurement carts\n\u274C Reject Cart - Reject procurement carts\n\uD83D\uDCE6 Check Inventory - Check item availability\n\uD83D\uDCE4 Submit Cart - Submit cart for approval\n\uD83D\uDD04 Duplicate Cart - Copy an existing cart\n\uD83D\uDDD1\uFE0F Delete Cart - Remove a draft cart\n\uD83D\uDCCB PO Status - Track purchase orders\n\uD83C\uDFED Supplier Lookup - Search suppliers\n\uD83D\uDCB0 Invoice Status - Check invoices\n\uD83D\uDCE5 GRN Status - Check goods receipts\n\uD83D\uDCCA Budget Status - Check budget utilization\n\uD83D\uDCDD RFQ Status - Check request for quotes\n\uD83D\uDCC3 Order History - View past orders\n\nJust select any option from the buttons above or type your question!"
    },
    "fallback": {
      "patterns": [
        ".*"
      ],
      "response": "I can't find a direct solution for your query. You can raise a ticket and our team will resolve it within 24 hours."
    }
  }
